{
  "name": "setup-unirtm",
  "description": "GitHub Action to setup UniRTM (Uni Runtime and Tools Manager)",
  "version": "0.0.12",
  "author": "Snowdream Tech",
  "private": true,
  "homepage": "https://github.com/snowdreamtech/setup-unirtm",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snowdreamtech/setup-unirtm.git"
  },
  "bugs": {
    "url": "https://github.com/snowdreamtech/setup-unirtm/issues"
  },
  "keywords": [
    "actions",
    "node",
    "setup",
    "unirtm"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "ci-test": "npx jest",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint . -c ./.eslintrc.yml",
    "package:index": "npx -y esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "package:post": "npx -y esbuild src/post.ts --bundle --platform=node --target=node20 --outfile=dist/post.js",
    "package": "npm run package:index && npm run package:post",
    "package:watch": "npm run package -- --watch",
    "test": "npx jest",
    "all": "npm run format:write && npm run lint && npm run test && npm run package",
    "prepare": "husky"
  },
  "license": "MIT",
  "jest": {
    "preset": "ts-jest",
    "verbose": true,
    "clearMocks": true,
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "./src/**"
    ]
  },
  "dependencies": {
    "@actions/cache": "^6.0.1",
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/glob": "^0.5.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/handlebars": "^4.0.40",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-plugin-jest": "^28.9.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,yml,json}": [
      "prettier --write"
    ]
  }
}
